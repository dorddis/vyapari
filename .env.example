# Vyapari Agent environment template
# Copy to `.env` and replace placeholders before running.

#
# App and server
#

# Runtime environment. Use `development` locally, `staging` / `production` elsewhere.
# `development` forces local SQLite and skips auth on REST endpoints.
APP_ENV=development

# FastAPI host/port binding.
HOST=0.0.0.0
PORT=8000

# Application log verbosity.
LOG_LEVEL=INFO

# Public base URL used for locally-served upload URLs + magic-link callbacks.
PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000

#
# OpenAI
#

OPENAI_API_KEY=your-openai-api-key

# Main conversation model for customer and owner agents.
OPENAI_MAIN_MODEL=gpt-5.4

# Lightweight classifier for escalation detection and cheap routing.
OPENAI_CLASSIFIER_MODEL=gpt-4.1-nano

# Speech-to-text for inbound voice notes.
OPENAI_STT_MODEL=gpt-4o-transcribe

# Text-to-speech for outbound voice replies.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# Set `false` to skip TTS reply generation.
VOICE_REPLY_ENABLED=true

#
# Database
#

# Async Postgres connection string. Ignored in `development` (local SQLite is forced).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vyapari_agent

# Supabase-style URL used as a fallback when DATABASE_URL is unset.
SUPABASE_DB_URL=

# Set `true` only for verbose SQL logs when debugging.
DATABASE_ECHO=false

# Connection pool sizing.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

#
# Channel mode
#

# `whatsapp` for real Cloud-API traffic, `web_clone` for the demo frontend.
CHANNEL_MODE=web_clone

#
# WhatsApp Cloud API (required when CHANNEL_MODE=whatsapp)
#

# Set `true` when running real WhatsApp traffic (enforces signature verification
# regardless of CHANNEL_MODE).
WHATSAPP_ENABLED=false

# Static token Meta uses during webhook subscribe handshake.
WHATSAPP_VERIFY_TOKEN=your-random-verify-token

# Graph access token (legacy single-tenant). Multi-tenant deployments store this
# per-tenant in whatsapp_channels.provider_config and resolve at request time.
WHATSAPP_ACCESS_TOKEN=your-meta-access-token

# WhatsApp Cloud API phone number id (legacy single-tenant).
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# WhatsApp Business Account id for template endpoints (legacy single-tenant).
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Graph API version.
WHATSAPP_API_VERSION=v21.0

# Meta app secret used to verify webhook signatures. Legacy single-tenant only;
# multi-tenant deployments resolve per-tenant from whatsapp_channels.
META_APP_SECRET=

#
# Encryption (REQUIRED)
#

# Fernet key used to encrypt per-tenant provider_config in whatsapp_channels.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, decrypt_secrets() raises and tenant credentials can't load.
VYAPARI_ENCRYPTION_KEY=

#
# REST API auth
#

# Legacy single-tenant bearer token. When set, requests without a per-business
# API key can still authenticate. Leave blank in multi-tenant production.
API_AUTH_TOKEN=

#
# Demo business defaults
#

DEFAULT_BUSINESS_ID=demo-sharma-motors
DEFAULT_BUSINESS_NAME=Sharma Motors
DEFAULT_BUSINESS_VERTICAL=used_cars
DEFAULT_OWNER_NAME=Rajesh
DEFAULT_OWNER_PHONE=919876543210

#
# Agent behavior
#

# Hard cap on tool calls per agent turn (anti-loop guard).
MAX_TOOL_CALLS_PER_TURN=8

# Prefix for slash-commands (/done, /login, etc).
COMMAND_PREFIX=/

# Relay session idle timeout before auto-close.
RELAY_SESSION_TIMEOUT_MINUTES=20

# Owner-hijack-before-agent-resumes idle window.
OWNER_ACTIVE_IDLE_MINUTES=15

# Escalation reminder threshold.
ESCALATION_RESPONSE_TIMEOUT_MINUTES=15

# Callback SLA shown to customers waiting for a human.
CALLBACK_SLA_MINUTES=15
