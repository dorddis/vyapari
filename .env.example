# Vyapari Agent environment template
# Copy this file to `.env` and replace placeholder values before running locally.
# Leave the optional WhatsApp / Meta catalogue variables blank if you are only using the web demo fallback.

#
# App and server
#

# Runtime environment. Use `development` locally and `production` on the deployed server.
APP_ENV=development

# FastAPI host binding.
HOST=0.0.0.0

# FastAPI port.
PORT=8000

# Application log verbosity.
LOG_LEVEL=INFO

# Public base URL for links generated by the app and for callback references.
PUBLIC_BASE_URL=http://localhost:8000

#
# OpenAI
#

# Primary OpenAI API key used for GPT-5, GPT-5 mini, transcribe, and TTS calls.
OPENAI_API_KEY=your-openai-api-key

# Optional OpenAI organization id if your account uses org-scoped billing.
OPENAI_ORG_ID=

# Optional OpenAI project id if you separate usage by project.
OPENAI_PROJECT_ID=

# Override only if you need a non-default OpenAI-compatible endpoint.
OPENAI_BASE_URL=https://api.openai.com/v1

# Main conversation model for customer and owner agents.
OPENAI_MAIN_MODEL=gpt-5.4

# Lightweight classifier model for escalation detection and other cheap routing checks.
OPENAI_CLASSIFIER_MODEL=gpt-5-mini

# Speech-to-text model for incoming voice notes.
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Text-to-speech model for outgoing voice replies. Leave blank if you are not building voice responses yet.
OPENAI_TTS_MODEL=

#
# Database
#

# Async PostgreSQL connection string used by FastAPI and agent tools.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vyapari_agent

# Set to `true` only when you need verbose SQL logs during debugging.
DATABASE_ECHO=false

# Connection pool size for the async database engine.
DATABASE_POOL_SIZE=10

# Extra burst connections allowed above the base pool size.
DATABASE_MAX_OVERFLOW=10

#
# Demo business defaults
#

# The single-business id used by the hackathon demo until multi-tenancy is added properly.
DEFAULT_BUSINESS_ID=demo-sharma-motors

# Seed business name shown in greetings and owner-facing context.
DEFAULT_BUSINESS_NAME=Sharma Motors

# Demo vertical used for presets, FAQs, and prompts.
DEFAULT_BUSINESS_VERTICAL=used_cars

# Default owner name used in handoff messages like "Rajesh from Sharma Motors here!".
DEFAULT_OWNER_NAME=Rajesh

# Owner phone number for escalation notifications and callback routing.
DEFAULT_OWNER_PHONE=+919876543210

#
# WhatsApp Cloud API
#

# Set to `true` when running the real WhatsApp Cloud API integration instead of web-demo-only mode.
WHATSAPP_ENABLED=false

# Static token used by Meta webhook verification during setup.
WHATSAPP_VERIFY_TOKEN=your-random-verify-token

# Meta Graph access token with WhatsApp messaging permissions.
WHATSAPP_ACCESS_TOKEN=your-meta-access-token

# WhatsApp Cloud API phone number id used in send-message endpoints.
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# WhatsApp Business Account id. Useful for setup flows and management APIs.
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Meta Graph API version used for messaging and catalogue calls.
WHATSAPP_API_VERSION=v21.0

# Meta app secret used to verify webhook signatures (`X-Hub-Signature-256`).
META_APP_SECRET=

#
# Meta Commerce Manager catalogue sync
#

# Set to `true` only when PostgreSQL changes should sync to a Meta Commerce catalogue.
META_CATALOG_SYNC_ENABLED=false

# Meta Commerce catalogue id for native WhatsApp product messages.
META_CATALOG_ID=

# Optional Meta app id for Graph API setup and future commerce workflows.
META_APP_ID=

#
# Agent behavior and guardrails
#

# Hard cap on tool calls per agent turn to avoid loops and runaway cost.
MAX_TOOL_CALLS_PER_TURN=8

# How long the owner can stay silent before the agent resumes after a manual hijack.
OWNER_ACTIVE_IDLE_MINUTES=15

# How long to wait before reminding the customer that the team will get back to them after escalation.
ESCALATION_RESPONSE_TIMEOUT_MINUTES=15

# Default callback wait promise shown to the customer when a human is unavailable.
CALLBACK_SLA_MINUTES=15
